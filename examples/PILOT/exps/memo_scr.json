{
    "prefix": "benchmark",
    "dataset": "cifar100",
    "memory_size": 2000,
    "memory_per_class":20,
    "fixed_memory": false,
    "shuffle": true,
    "init_cls": 10,
    "increment": 10,
    "model_name": "memo",
    "backbone_type": "memo_resnet18",
    "pretrained": false,
    "train_base": true,
    "train_adaptive": false,
    "debug": false,
    "skip": false,
    "device": ["0"],
    "seed":[1993],
    
    "optimizer": "sgd", 
    "scheduler": "steplr",
    "init_epoch": 200,
    "t_max": null,
    "init_lr" : 0.1,
    "init_weight_decay" : 5e-4,
    "init_lr_decay" : 0.1,
    "init_milestones" : [60,120,170],
    "milestones" : [80,120,150],
    "epochs": 170,
    "lrate" : 0.1,
    "batch_size" : 128,
    "weight_decay" : 2e-4,
    "lrate_decay" : 0.1,
    "alpha_aux" : 1.0,

    "save_sharpness_json": true,
    "sharpness_use_test_loader": true,
    "sharpness_json_dir": "./sharpness_json_bidirectional",
    "sharpness_alpha_list": [-0.5, -0.3, -0.2, -0.1, -0.05, -0.02, -0.01, 0.0, 0.01, 0.02, 0.05, 0.1, 0.2, 0.3, 0.5],
    "sharpness_maxIter": 100,
    "sharpness_tol": 0.001,

    "save_conflict_stats": false,
    "conflict_stats_dir": "./conflict_stats",
    "conflict_probe_batches": 5,
    "save_metrics_json": false,
    "metrics_json_dir": "./metrics_json"
}
