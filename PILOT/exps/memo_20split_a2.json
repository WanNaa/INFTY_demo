{
    "prefix": "reproduce_unigradfs",
    "dataset": "cifar100",
    "memory_size": 2000,
    "memory_per_class": 20,
    "fixed_memory": false,
    "shuffle": true,
    "init_cls": 5,
    "increment": 5,
    "model_name": "memo",
    "backbone_type": "memo_resnet32",
    "pretrained": false,
    "train_base": true,
    "train_adaptive": false,
    "debug": false,
    "skip": false,
    "enable_weight_align": true,
    "device": ["0"],
    "seed": [1993],

    "scheduler": "steplr",
    "init_epoch": 200,
    "t_max": null,
    "init_lr": 0.1,
    "init_weight_decay": 0.0005,
    "init_lr_decay": 0.1,
    "init_milestones": [60, 120, 170],
    "milestones": [80, 120, 150],
    "epochs": 170,
    "lrate": 0.1,
    "batch_size": 128,
    "weight_decay": 0.0002,
    "lrate_decay": 0.1,
    "alpha_aux": 2.0,

    "save_metrics_json": true,
    "metrics_json_dir": "./pilot_repro_metrics"
}
